# Password required to unlock the Auctioneer Console. Anyone with this
# password can control the auction; the Team View doesn't need it.
# Leave unset and the console stays locked for everyone.
AUCTIONEER_PASSWORD=changeme
PORT=4000

# Production only: comma-separated list of allowed client origins, e.g.
#   ALLOWED_ORIGIN=https://your-auction-room.netlify.app
# Leave unset locally to allow any origin.
ALLOWED_ORIGIN=
